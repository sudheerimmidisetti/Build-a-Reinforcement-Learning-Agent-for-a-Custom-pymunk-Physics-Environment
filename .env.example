# ── Training ──────────────────────────────────────────────────────────────
TRAIN_TIMESTEPS=500000
REWARD_TYPE=shaped
SAVE_PATH=models
LOG_DIR=logs
SEED=42
N_ENVS=4

# ── Evaluation ────────────────────────────────────────────────────────────
MODEL_PATH=models/final_model.zip
EPISODES=10

# ── Rendering & GIF ──────────────────────────────────────────────────────
FPS=30
GIF_OUTPUT=media/agent_final.gif

# ── Plotting ──────────────────────────────────────────────────────────────
BASELINE_LOG=logs/baseline
SHAPED_LOG=logs/shaped
PLOT_OUTPUT=plots/reward_comparison.png

# ── Pygame (headless mode for Docker / CI) ────────────────────────────────
SDL_VIDEODRIVER=dummy
SDL_AUDIODRIVER=dummy
